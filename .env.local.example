# ============================================================
# FIXOPS — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS COMMITER .env.local dans git
# ============================================================

# Supabase — Récupérer dans : Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE-ANON-KEY

# Optionnel — pour les opérations admin côté serveur uniquement
# SUPABASE_SERVICE_ROLE_KEY=VOTRE-SERVICE-ROLE-KEY

# Optionnel — URL de production (Vercel la définit automatiquement)
# NEXT_PUBLIC_SITE_URL=https://fixops.vercel.app
